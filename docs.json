{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Passform Docs",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": ["index", "quickstart"]
          },
          {
            "group": "Guides",
            "pages": ["guides/image-dimensions"]
          },
          {
            "group": "Integrations",
            "pages": ["guides/zapier", "guides/n8n", "guides/mcp"]
          }
        ]
      },
      {
        "tab": "API reference",
        "openapi": "/api-reference/openapi.json"
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Support",
          "href": "mailto:support@passform.io",
          "icon": "envelope"
        },
        {
          "anchor": "LinkedIn",
          "href": "https://linkedin.com/company/passform-io",
          "icon": "linkedin"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/logo-black.png",
    "dark": "/logo/logo-white.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@passform.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.passform.io"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "linkedin": "https://linkedin.com/company/passform-io"
    }
  }
}
